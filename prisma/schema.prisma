generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migreringar behöver direkt Postgres (inte PgBouncer/Neon pooler) — annars P1002 på advisory lock.
  directUrl = env("DIRECT_URL")
}

model Room {
  id        String   @id @default(cuid())
  slug      String   @unique
  pinHash   String
  name      String?
  /** Om true: vem som helst med länken kan läsa karta/lista utan PIN; like/redigera kräver fortfarande PIN. */
  publicRead Boolean  @default(false)
  createdAt DateTime @default(now())
  cities    City[]
}

model City {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  /** Valfri emoji/flagga som visas i stadsmenyn (t.ex. 🇸🇪). */
  emoji     String?
  /** Markerar vilken stad som laddas som standard vid besök. Max en per room. */
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  spots     Spot[]

  @@unique([roomId, slug])
}

model Spot {
  id             String             @id @default(cuid())
  cityId         String
  city           City               @relation(fields: [cityId], references: [id], onDelete: Cascade)
  googlePlaceId  String
  name           String
  neighborhood   String?
  lat            Float?
  lng            Float?
  shortAddress   String?
  /** En eller flera kategorier (t.ex. lunch + bar). */
  categories     String[]           @default([])
  emoji          String?
  createdAt      DateTime           @default(now())
  recommendations Recommendation[]
  plusses        SpotPlus[]

  @@unique([cityId, googlePlaceId])
  @@index([cityId, neighborhood])
}

/** Anonym “plussa” — en rad per (spot, voterKey); voterKey är hash, ingen PII. */
model SpotPlus {
  id        String   @id @default(cuid())
  spotId    String
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  voterKey  String
  createdAt DateTime @default(now())

  @@unique([spotId, voterKey])
  @@index([spotId])
}

model Recommendation {
  id              String   @id @default(cuid())
  spotId          String
  spot            Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  contributorName String
  createdAt       DateTime @default(now())

  @@unique([spotId, contributorName])
}
