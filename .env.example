# Google Cloud API key with Places API (New) enabled
GOOGLE_MAPS_API_KEY=

# Postgres (Neon, Supabase, etc.) - required for Vercel. Local: same URL or local Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Hemlig nyckel för rumssession (httpOnly-kaka, 90 dagar). Sätt en lång slumpmässig sträng i produktion.
ROOM_TOKEN_SECRET=

# Salt för anonym "plussa"-röst (hash av enhets-token + IP). Lång slump i produktion.
# VOTER_PEPPER=

# Publik bas-URL (og:image, metadata). På Vercel: https://ditt-projekt.vercel.app eller egen domän.
# NEXT_PUBLIC_SITE_URL=https://friend-spots.vercel.app

# Optional default city on home page (slug from database)
# DEFAULT_CITY_SLUG=new-york
