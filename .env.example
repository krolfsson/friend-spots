# =============================================================================
# Mall — committas till git. Kopiera innehållet till .env.local (samma mapp som
# package.json), fyll i värden, starta om dev-servern.
# Fil att redigera lokalt: .env.local  (finns hos dig; checkas inte in)
# =============================================================================

# --- Google (ofta samma nyckel om båda API:erna är på i samma Cloud-projekt) ---
# Server: Places m.m.
GOOGLE_MAPS_API_KEY=

# Webbläsare: kartvy (Maps JavaScript API). Måste börja med NEXT_PUBLIC_.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Postgres (Neon, Supabase, etc.) — required for Vercel.
# Neon: använd *poolad* URL till DATABASE_URL (bra för serverless) och *direkt* URL till DIRECT_URL.
# Lokalt utan pooler: sätt samma värde i båda.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Hemlig nyckel för rumssession (httpOnly-kaka, 90 dagar). Sätt en lång slumpmässig sträng i produktion.
ROOM_TOKEN_SECRET=

# Salt för anonym "plussa"-röst (hash av enhets-token + IP). Lång slump i produktion.
# VOTER_PEPPER=

# Publik bas-URL (og:image, metadata). På Vercel: https://ditt-projekt.vercel.app eller egen domän.
# NEXT_PUBLIC_SITE_URL=https://friend-spots.vercel.app

# Optional default city on home page (slug from database)
# DEFAULT_CITY_SLUG=new-york

# Admin dashboard PIN (mapsies.com/admin)
ADMIN_PIN=
